DATABASE_URL=postgresql://polynux:polynux@localhost:5432/polynux
BETTER_AUTH_SECRET=change-me-to-a-random-32-character-string
BETTER_AUTH_URL=http://localhost:3000

# Set to true to make all Xeno grow/breed times 1 second (dev testing only)
XENO_DEV=false

# Used by scripts/generate-hack-voice-lines.ts to generate missing RELAY VO lines
ELEVENLABS_API_KEY=

# Used by scripts/generate-hack-images.ts to generate missing HackOps images
OPENAI_API_KEY=

# AI assistant (server-side only). OpenRouter model slugs are listed at https://openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
